// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VideoVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum VideoStatus {
  EMPTY
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  channel        Channel?
}

model Channel {
  id          String   @id @default(uuid())
  handle      String   @unique
  name        String
  banner      String?
  avatar      String?
  description String?
  links       String[]

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  videos   Video[]
  likes    Like[]
  comments Comment[]

  subscriptions Subscription[] @relation("ViewerSubscriptions")
  subscribers   Subscription[] @relation("CreatorSubscribers")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([name])
}

model Video {
  id          String    @id @default(uuid())
  title       String
  description String?
  videoUrl    String
  thumbnail   String?
  duration    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  visibility VideoVisibility @default(UNLISTED) // [unlisted, public, ban]
  status     VideoStatus @default(EMPTY) // [empty, pending, uploaded]

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])

  likes          Like[]
  comments       Comment[]

  // @@index([title]) // not indexing title as it can be long and we will be using full text search for searching videos by title and description
  // Later we’ll do Postgres full-text or external search. For now, we can just filter by channel and visibility.
  @@index([channelId])
  @@index([createdAt])
  @@index([visibility, status, createdAt]) //feeds (pulic videos, uplodaded videos, newest first)
}

model Like {
  viewerId String
  videoId  String

  reaction ReactionType @default(LIKE) // [Like, Dislike]

  viewer Channel  @relation(fields: [viewerId], references: [id])
  video  Video @relation(fields: [videoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([viewerId, videoId])
  @@index([videoId])
}

model Comment {
  id   String @id @default(uuid())
  text String

  viewerId String
  videoId  String

  viewer Channel @relation(fields: [viewerId], references: [id])
  video  Video   @relation(fields: [videoId], references: [id])

  // saving it for v1.1
  // parentId String?
  // parent  Comment?  @relation("Thread", fields: [parentId], references: [id])
  // replies Comment[] @relation("Thread")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([videoId, createdAt]) // for fetching comments for a video sorted by newest first

}

model Subscription {
  viewerId  String
  creatorId String
  createdAt DateTime @default(now())

  viewer  Channel @relation("ViewerSubscriptions", fields: [viewerId], references: [id])
  creator Channel @relation("CreatorSubscribers", fields: [creatorId], references: [id])

  @@id([viewerId, creatorId])
  @@index([creatorId])
}
